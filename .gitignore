```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/
*.log
coverage/
htmlcov/
.coverage

# Editors and IDE
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.PyInstaller/
```